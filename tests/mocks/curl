#!/usr/bin/env bash
# Minimal curl mock for tests. It prints canned JSON based on the URL.
# Accepts many flags; we only inspect the last argument as URL.
set -euo pipefail
url="${@: -1}"
# emulate headers acceptance
if [[ "$url" == *"/api/user/login"* ]]; then
  cat <<JSON
{"displayName":"Test","username":"tester","token":"test-token-abcdef","info":{"version":"1.0"}}
JSON
  exit 0
fi
if [[ "$url" == *"/api/zones/records/get"* ]]; then
  cat <<JSON
{"response":{"zone":{"name":"example.com"},"records":[{"name":"example.com","type":"A","rData":{"ipAddress":"1.2.3.4"}},{"name":"example.com","type":"AAAA","rData":{"ipAddress":"::1"}}]},"server":"mock","status":"ok"}
JSON
  exit 0
fi
# Default: mimic network failure
echo "curl-mock: unknown URL: $url" >&2
exit 7
